{
    "name": "agromind-backend",
    "version": "1.0.0",
    "description": "AgroMind Backend API Server",
    "type": "module",
    "main": "src/server.js",
    "scripts": {
        "dev": "nodemon src/server.js",
        "start": "node src/server.js",
        "migrate": "npx prisma migrate dev",
        "migrate:deploy": "npx prisma migrate deploy",
        "seed": "node src/prisma/seed.js",
        "studio": "npx prisma studio",
        "test": "jest",
        "test:watch": "jest --watch",
        "postinstall": "npx prisma generate"
    },
    "keywords": [
        "agriculture",
        "ai",
        "farm-management"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@prisma/client": "^5.8.0",
        "axios": "^1.6.5",
        "bcryptjs": "^2.4.3",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "form-data": "^4.0.5",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "sharp": "^0.33.1"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "prisma": "^5.8.0",
        "supertest": "^6.3.3"
    }
